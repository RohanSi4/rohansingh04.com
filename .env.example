# vercel kv (upstash redis) -- auto-set by vercel integration
KV_REST_API_URL=
KV_REST_API_TOKEN=

# spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# github
GITHUB_TOKEN=


# optional strava sync (the local marathon publisher is the primary source)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=
STRAVA_REDIRECT_URI=
STRAVA_SYNC_SECRET=
